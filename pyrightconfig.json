{
  "venvPath": "backend",
  "venv": ".venv",
  "pythonVersion": "3.13",
  "pythonPlatform": "Darwin",
  "typeCheckingMode": "basic",
  "include": ["backend"],
  "exclude": [
    "**/node_modules",
    "**/__pycache__",
    "frontend",
    ".next",
    ".venv"
  ],
  "reportMissingImports": true,
  "reportMissingModuleSource": false
}
